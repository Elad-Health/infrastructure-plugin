# SQL Server Connection
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=master

# Authentication - Windows Auth (default)
# Leave MSSQL_USER and MSSQL_PASSWORD empty for Windows Authentication
# The service will use the credentials of the account running the process

# Authentication - SQL Auth (optional)
# Uncomment and fill these to use SQL Server authentication instead
# MSSQL_USER=your_username
# MSSQL_PASSWORD=your_password

# Connection options
MSSQL_ENCRYPT=false
MSSQL_TRUST_SERVER_CERTIFICATE=true
MSSQL_CONNECTION_TIMEOUT=30000
MSSQL_REQUEST_TIMEOUT=30000
